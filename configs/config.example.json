{
  // 如果你的 NapCat/OneBot 反向 WebSocket 需要 token，在这里填写；不需要可留空。
  "token": "请填写你的 TOKEN（如需）",

  // Claude / GPT / Grok / DeepSeek 均从环境变量或本配置读取。
  // 注意：真实密钥不要提交到 GitHub；建议复制为 configs/config.json 后只在服务器本地填写。
  "claude_api_key": "YOUR_CLAUDE_API_KEY",
  "claude_api_base": "https://agentrouter.org",
  "claude_model": "claude-sonnet-4-5-20250929",

  "gpt_api_key": "YOUR_GPT_API_KEY",
  "gpt_api_base": "https://codex-api.packycode.com/v1",
  "gpt_model": "gpt-5.1",

  "grok_api_key": "YOUR_GROK_API_KEY",
  "grok_api_base": "https://happyapi.org/v1",
  "grok_model": "grok-3",

  "deepseek_api_key": "YOUR_DEEPSEEK_API_KEY",
  "deepseek_api_base": "https://api.deepseek.com",
  "deepseek_model": "deepseek-v4-flash",

  // Gemini 图片生成。/img 支持写尺寸：/img 1024x768 一只猫。
  "gemini_api_key": "YOUR_GEMINI_API_KEY",
  "gemini_api_base": "https://generativelanguage.googleapis.com/v1beta",
  "gemini_image_model": "gemini-2.5-flash-image",

  // Steam Web API。steam_api_key_domain 只是你在 Steam 申请 key 时绑定的域名记录。
  // 不要把真实 steam_api_key 提交；本示例只保留占位符。
  "steam_api_key": "YOUR_STEAM_API_KEY",
  "steam_api_key_domain": "book.yamatu.xyz",
  "steam_api_base": "https://api.steampowered.com",
  "steam_monitor_groups": ["123456789"],
  "steam_poll_interval": "60s",

  // 超过该字符数的回复优先用合并转发折叠；失败时自动回退分段发送。
  "long_forward_threshold": 3000,

  // agent 调用模型前的最大上下文字符数，超过会折叠较早历史。
  "max_context_chars": 24000,

  "amap_api_key": "你的高德Key",

  // B 站视频解析接口；失败时会回退到网页爬取。
  "bilibili_api_base": "https://api.bilibili.com/x/web-interface/view",

  "packycode_userinfo_url": "https://codex.packycode.com/api/backend/users/info",
  "packycode_user_jwt": "你的 JWT（如需）",

  // 支持 http(s) 代理；socks5 会退化为直连，除非后续替换为 socks transport。
  "socks5_proxy": "socks5://127.0.0.1:41457"
}
